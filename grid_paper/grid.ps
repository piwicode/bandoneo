%!PS
% Copyright 2023 Eamon Caddigan, CC BY-SA 4.0
% https://www.eamoncaddigan.net/posts/postscript-graph-paper/
% Modified 2025 Pierre Labatut, CC BY-SA 4.0

% Adjust these to suit your needs, units specified in "points" (1/72 inch)
% 1 inch is 25.4 millimeter.
/w 595 def /h 842 def      % A4 paper
/sp 5 72 mul 25.4 div def  % Grid spacing (5 mm here)
/st 2 72 mul 300 div def   % Stroke width (1 'dots' in a 300 dpi resolution)
/co 0 def                  % Gray-level of the line (0 = black, 1 = white)
/wscale 15 14.45 div def              % Printer width scale factor.
/hscale 15 15.55 div def    % Printer height scale factor.

% Define xres and yres in dpi
currentpagedevice /HWResolution get  % Push the resolution array onto the stack
aload pop                            % Get xres and yres and drop the array.
/xres exch def
/yres exch def

% Page and line setup
<< /PageSize [w h] >> setpagedevice
co setgray
st setlinewidth

% Create vertical lines
0 sp wscale mul w
{
  % Align the line on the dot matrix precisely, to improve thickness consistency.
  xres mul 72 div round 72 mul xres div
  dup 
  0 moveto
  h lineto
} for

% Create horizontal lines
0 sp hscale mul h
{
  yres mul 72 div round 72 mul yres div
  dup
  0 exch moveto
  w exch lineto
} for

% Draw
stroke

% Process and eject the page
showpage
