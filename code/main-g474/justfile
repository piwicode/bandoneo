default:
    @just --list

# Generate build system into build/Debug. Re-run after adding/removing source files or changing CMakeLists.txt.
init_build:
    cmake --preset Debug

build:
    cmake --build --preset Debug

# Record this board's chip UID in the registry. Run once per board before the first flash.
registry_add:
    ../registry/registry.py add $(basename $(pwd))

flash:
    name=$(basename $(pwd)) && \
    ../registry/registry.py check "$name" && \
    arm-none-eabi-objcopy -O binary build/Debug/$name.elf build/Debug/$name.bin && \
    st-flash --reset write build/Debug/$name.bin 0x08000000

# Reset the board via STLink
reset:
    st-flash reset

# Open UART debug console via STLink VCP (resolves the right /dev/ttyACMx automatically)
console:
    tio /dev/serial/by-id/usb-STMicroelectronics_STLINK-V3_*

# Stream SWO ITM port 0 output (core clock = 16 MHz HSI)
trace_swo:
    st-trace --clock=16m
