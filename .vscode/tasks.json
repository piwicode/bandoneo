{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "d='${fileDirname}'; while [ ! -f \"$d/justfile\" ] && [ \"$d\" != '/' ]; do d=$(dirname \"$d\"); done; cd \"$d\" && just build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": {
                "owner": "gcc",
                "fileLocation": ["absolute"],
                "pattern": {
                    "regexp": "^(.+):(\\d+):(\\d+):\\s+(warning|error):\\s+(.+)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "Build & Flash",
            "dependsOn": ["Build Debug", "Flash"],
            "dependsOrder": "sequence",
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Flash",
            "type": "shell",
            "command": "d='${fileDirname}'; while [ ! -f \"$d/justfile\" ] && [ \"$d\" != '/' ]; do d=$(dirname \"$d\"); done; cd \"$d\" && just flash",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
