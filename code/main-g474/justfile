default:
    @just --list

build:
    cmake --build --preset Debug

flash:
    arm-none-eabi-objcopy -O binary build/Debug/main-g474.elf build/Debug/main-g474.bin
    st-flash --reset write build/Debug/main-g474.bin 0x08000000

# Reset the board via STLink
reset:
    st-flash reset

# Open UART debug console via STLink VCP (resolves the right /dev/ttyACMx automatically)
console:
    tio /dev/serial/by-id/usb-STMicroelectronics_STLINK-V3_*

# Stream SWO ITM port 0 output (core clock = 16 MHz HSI)
trace_swo:
    st-trace --clock=16m
